[Unit]
Description=Holddetection FastAPI Background Service
After=network.target

[Service]
User=dev_pipe
WorkingDirectory=/home/dev_pipe/holddetection
ExecStart=/home/dev_pipe/holddetection/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8010
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
